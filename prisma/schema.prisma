// Prisma schema — PDF Master Pro
// Banco alvo em produção: Postgres (DATABASE_URL=postgresql://...)
// Banco em dev: SQLite (DATABASE_URL="file:./dev.db") para evitar dependências externas
// O schema abaixo é compatível com ambos (sem tipos exclusivos de Postgres).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Auth.js / NextAuth — modelos padrão do @next-auth/prisma-adapter
// ===========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================================================================
// Usuário e plano
// ===========================================================================
// Observação: SQLite (dev) não suporta enums. Usamos String com validação
// no código. Em Postgres, esses campos podem virar enum sem mudar a API.

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("USER") // USER | ADMIN
  planCode      String    @default("FREE") // FREE | PREMIUM | BUSINESS
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  usageLogs    UsageLog[]
  payments     Payment[]
  subscription Subscription?
}

model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  planCode               String    @default("FREE")  // FREE | PLUS | PREMIUM | ENTERPRISE
  status                 String    @default("FREE")  // FREE | PENDING_PAYMENT | ACTIVE | PAST_DUE | CANCELED | EXPIRED
  provider               String?   // mercado_pago | stripe | manual
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

// ===========================================================================
// Billing — Fase 5
// Pagamentos e assinaturas dos planos Plus / Premium / Enterprise.
// So atualiza User.planCode apos confirmacao via webhook.
// ===========================================================================

model Payment {
  id                  String   @id @default(cuid())
  userId              String
  subscriptionId      String?
  provider            String   // mercado_pago | stripe | manual
  providerPaymentId   String?
  providerCheckoutId  String?
  amount              Int      // em centavos (BRL) ou cents (USD)
  currency            String   // BRL | USD
  status              String   // pending | approved | paid | failed | canceled | refunded
  planCode            String   // PLUS | PREMIUM | ENTERPRISE
  billingCycle        String   // monthly | yearly
  paymentMethod       String?
  checkoutUrl         String?
  rawEvent            String?  // JSON serializado (apenas dados nao-sensiveis)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, providerPaymentId])
  @@index([provider, providerCheckoutId])
}

// ===========================================================================
// Auditoria de uso (cota logada)
// ===========================================================================

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  tool      String
  sizeBytes Int
  success   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
